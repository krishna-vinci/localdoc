## Backend Database Connection
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/localdocs

## Next.js Server-to-Backend URL (Docker internal network)
INTERNAL_API_URL=http://backend:4320

## Next.js Client-to-Backend URL (Browser accessible)
NEXT_PUBLIC_API_URL=http://localhost:4320

## Next.js Allowed Hostnames
NEXT_ALLOWED_DEV_ORIGINS=localhost,127.0.0.1,0.0.0.0

## FastAPI Allowed CORS Origins (include frontend URLs)
CORS_ORIGINS=["http://localhost:4321","http://127.0.0.1:4321"]

## PostgreSQL Container Initialization Credentials
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=localdocs
