# Environment variables for LocalDocs Hub
# Copy this file to .env and fill in your values

# App
APP_NAME=LocalDocs Hub
APP_VERSION=0.1.0
DEBUG=true

# Server
HOST=0.0.0.0
PORT=8000

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/localdocs
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# JWT Auth
SECRET_KEY=change-me-in-production-use-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# File watching debounce (seconds)
WATCHDEBOUNCE_SECONDS=0.5
